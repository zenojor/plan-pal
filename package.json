{
  "name": "plan-pal-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:frontend": "pnpm --dir frontend dev",
    "build:frontend": "pnpm --dir frontend build",
    "lint:frontend": "pnpm --dir frontend lint",
    "preview:frontend": "pnpm --dir frontend preview",
    "test:backend": "mvn -f backend/pom.xml test",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "build:backend": "mvn -f backend/pom.xml package",
    "build": "pnpm build:frontend && pnpm test:backend"
  }
}
